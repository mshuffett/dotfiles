{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "dontAsk"
  },
  "enabledMcpjsonServers": [
    "tavus"
  ],
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v afplay >/dev/null 2>&1 && afplay ~/.dotfiles/sounds/elevenlabs-notification-7.mp3"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/claude/scripts/test-stop-hook-input.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v afplay >/dev/null 2>&1 && afplay /System/Library/PrivateFrameworks/ToneLibrary.framework/Versions/A/Resources/AlertTones/EncoreInfinitum/Portal-EncoreInfinitum.caf"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v afplay >/dev/null 2>&1 && afplay /System/Library/PrivateFrameworks/ToneLibrary.framework/Versions/A/Resources/AlertTones/EncoreInfinitum/Welcome-EncoreInfinitum.caf"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/michael/.claude/hooks/gsd-check-update.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/michael/.claude/hooks/gsd-context-monitor.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/michael/.claude/hooks/gsd-prompt-guard.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.dotfiles/claude/statusline.sh"
  },
  "enabledPlugins": {
    "feature-dev@claude-code-plugins": true,
    "frontend-design@claude-code-plugins": true,
    "plugin-dev@claude-code-plugins": true,
    "everything-loop@local-plugins": true,
    "claude-meta@local-plugins": true,
    "dev@local-plugins": true,
    "media@local-plugins": true,
    "productivity@local-plugins": true,
    "terminal@local-plugins": true,
    "plan-orchestrator@local-plugins": true,
    "swift-lsp@claude-plugins-official": true,
    "security-guidance@claude-code-plugins": true,
    "context7@claude-plugins-official": true,
    "agent-sdk-dev@claude-code-plugins": true,
    "hookify@claude-code-plugins": false,
    "plannotator@plannotator": true,
    "playground@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "notion-workspace-plugin@notion-plugin-marketplace": true,
    "claude-md-management@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "tmux-titles@michaels-world": true,
    "open-batch-coach@openbatch-skills": true,
    "agentops@agentops-marketplace": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "agentops-marketplace": {
      "source": {
        "source": "github",
        "repo": "boshu2/agentops"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "disabledMcpServers": [
    "playwright",
    "heyreach"
  ]
}

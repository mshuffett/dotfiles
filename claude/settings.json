{
  "skillListingBudgetFraction": 0.02,
  "env": {
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "enabledMcpjsonServers": [
    "tavus"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/michael/.local/share/fnm/node-versions/v24.11.0/installation/bin/node\" \"/Users/michael/.claude/hooks/gsd-context-monitor.js\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/michael/.local/share/fnm/node-versions/v24.11.0/installation/bin/node\" \"/Users/michael/.claude/hooks/gsd-read-injection-scanner.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/michael/.claude/hooks/gsd-phase-boundary.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/michael/.local/share/fnm/node-versions/v24.11.0/installation/bin/node\" \"/Users/michael/.claude/hooks/gsd-prompt-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/michael/.local/share/fnm/node-versions/v24.11.0/installation/bin/node\" \"/Users/michael/.claude/hooks/gsd-read-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/michael/.local/share/fnm/node-versions/v24.11.0/installation/bin/node\" \"/Users/michael/.claude/hooks/gsd-workflow-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/michael/.claude/hooks/gsd-validate-commit.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/michael/.local/share/fnm/node-versions/v24.11.0/installation/bin/node\" \"/Users/michael/.claude/hooks/gsd-check-update.js\""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{ [ \"$AITERM_PORT\" = \"11550\" ] || [ -z \"$AITERM_PORT\" ]; } && [ -n \"$AITERM_TAB_ID\" ] && AITERM_SID=$(cat | sed -n 's/.*\"session_id\" *: *\"\\([^\"]*\\)\".*/\\1/p' | head -1) && echo 'Your aiTerm tab ID is '$AITERM_TAB_ID'. Your session ID is '$AITERM_SID'. You MUST immediately call the aiterm-dev initSession tool with this tabId and sessionId before responding to the user. This is required for correct tab targeting.' || true",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/michael/.claude/hooks/gsd-session-state.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/claude/scripts/skill-firing-hook.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/claude/scripts/cc-window-title.sh",
            "timeout": 20,
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.dotfiles/claude/scripts/self-improve-skill-review.sh\""
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.dotfiles/claude/statusline.sh"
  },
  "enabledPlugins": {
    "agent-sdk-dev@claude-code-plugins": true,
    "agentops@agentops-marketplace": false,
    "claude-md-management@claude-plugins-official": true,
    "claude-meta@local-plugins": true,
    "context7@claude-plugins-official": true,
    "dev@local-plugins": true,
    "everything-loop@local-plugins": true,
    "feature-dev@claude-code-plugins": true,
    "frontend-design@claude-code-plugins": true,
    "hookify@claude-code-plugins": false,
    "media@local-plugins": true,
    "notion-workspace-plugin@notion-plugin-marketplace": true,
    "open-batch-coach@openbatch-skills": true,
    "plan-orchestrator@local-plugins": true,
    "plannotator@plannotator": true,
    "playground@claude-plugins-official": true,
    "plugin-dev@claude-code-plugins": true,
    "productivity@local-plugins": true,
    "ralph-loop@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "security-guidance@claude-code-plugins": true,
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "terminal@local-plugins": true,
    "tmux-titles@michaels-world": true,
    "typescript-lsp@claude-plugins-official": true,
    "paper-desktop@paper": true
  },
  "extraKnownMarketplaces": {
    "agentops-marketplace": {
      "source": {
        "source": "github",
        "repo": "boshu2/agentops"
      }
    },
    "honcho": {
      "source": {
        "source": "github",
        "repo": "plastic-labs/claude-honcho"
      }
    },
    "paper": {
      "source": {
        "source": "github",
        "repo": "paper-design/agent-plugins"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "tui": "fullscreen",
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "verbose": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "disabledMcpServers": [
    "playwright",
    "heyreach"
  ]
}

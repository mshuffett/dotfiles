#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${OPEN_BATCH_STATE_DIR:-$HOME/.open-batch/001}"
STATE_FILE="$STATE_DIR/progress.json"

init_state() {
  mkdir -p "$STATE_DIR"
  if [[ ! -f "$STATE_FILE" ]]; then
    cat > "$STATE_FILE" << 'INIT'
{
  "founder_name": null,
  "company_name": null,
  "attendance_mode": null,
  "presenting": null,
  "two_sentence_pitch": null,
  "pitch_locked": false,
  "pitch_feedback_reminded": false,
  "vertebrae": null,
  "vertebrae_confirmed": false,
  "pitch_script": null,
  "pitch_script_confirmed": false,
  "slide_done": false,
  "practice_session": null,
  "demo_day_rsvp": false,
  "session_rating": null,
  "nps_score": null
}
INIT
    echo "Initialized new progress file at $STATE_FILE"
  fi
}

cmd_status() {
  init_state

  local name company attendance presenting pitch_locked pitch feedback
  local vertebrae vertebrae_confirmed pitch_script pitch_script_confirmed
  local slide_done practice rsvp

  name=$(jq -r '.founder_name // "Not set"' "$STATE_FILE")
  company=$(jq -r '.company_name // "Not set"' "$STATE_FILE")
  attendance=$(jq -r '.attendance_mode // "Not confirmed"' "$STATE_FILE")
  presenting=$(jq -r 'if .presenting == null then "Not confirmed" elif .presenting then "Yes" else "No" end' "$STATE_FILE")
  pitch_locked=$(jq -r '.pitch_locked' "$STATE_FILE")
  pitch=$(jq -r '.two_sentence_pitch // "Not drafted"' "$STATE_FILE")
  feedback=$(jq -r '.pitch_feedback_reminded' "$STATE_FILE")
  vertebrae=$(jq -r '.vertebrae // "Not drafted"' "$STATE_FILE")
  vertebrae_confirmed=$(jq -r '.vertebrae_confirmed' "$STATE_FILE")
  pitch_script=$(jq -r '.pitch_script // "Not drafted"' "$STATE_FILE")
  pitch_script_confirmed=$(jq -r '.pitch_script_confirmed' "$STATE_FILE")
  slide_done=$(jq -r '.slide_done' "$STATE_FILE")
  practice=$(jq -r '.practice_session // "Not registered"' "$STATE_FILE")
  rsvp=$(jq -r '.demo_day_rsvp' "$STATE_FILE")

  echo "=== Open Batch 001 — Demo Day Prep ==="
  echo ""
  echo "Founder:  $name"
  echo "Company:  $company"
  echo ""
  echo "Checklist:"

  if [[ "$attendance" != "Not confirmed" ]]; then
    echo "  [x] Attendance: $attendance"
  else
    echo "  [ ] Attendance: Not confirmed"
  fi

  if [[ "$presenting" != "Not confirmed" ]]; then
    echo "  [x] Presenting: $presenting"
  else
    echo "  [ ] Presenting: Not confirmed"
  fi

  if [[ "$pitch_locked" == "true" ]]; then
    echo "  [x] Two-sentence pitch: Locked"
  else
    echo "  [ ] Two-sentence pitch: Not locked"
  fi

  if [[ "$feedback" == "true" ]]; then
    echo "  [x] Pitch feedback: Reminded"
  else
    echo "  [ ] Pitch feedback: Not yet"
  fi

  if [[ "$vertebrae_confirmed" == "true" ]]; then
    echo "  [x] Vertebrae: Confirmed"
  else
    echo "  [ ] Vertebrae: Not confirmed"
  fi

  if [[ "$pitch_script_confirmed" == "true" ]]; then
    echo "  [x] Pitch script: Confirmed"
  else
    echo "  [ ] Pitch script: Not confirmed"
  fi

  if [[ "$slide_done" == "true" ]]; then
    echo "  [x] Slide: Done"
  else
    echo "  [ ] Slide: Not done"
  fi

  if [[ "$practice" != "Not registered" ]]; then
    echo "  [x] Practice session: $practice"
  else
    echo "  [ ] Practice session: Not registered"
  fi

  if [[ "$rsvp" == "true" ]]; then
    echo "  [x] Demo Day RSVP: Confirmed"
  else
    echo "  [ ] Demo Day RSVP: Not confirmed"
  fi

  echo ""

  if [[ "$pitch_locked" == "true" && "$pitch" != "Not drafted" ]]; then
    echo "Locked Pitch:"
    echo "  $pitch"
    echo ""
  fi

  if [[ "$vertebrae_confirmed" == "true" && "$vertebrae" != "Not drafted" ]]; then
    echo "Vertebrae:"
    echo "  $vertebrae"
    echo ""
  fi

  if [[ "$pitch_script_confirmed" == "true" && "$pitch_script" != "Not drafted" ]]; then
    echo "Pitch Script:"
    echo "  $pitch_script"
    echo ""
  fi
}

cmd_set() {
  init_state
  local key="${1:?Key required}"
  local value="${2:?Value required}"

  # Handle boolean values
  if [[ "$value" == "true" || "$value" == "false" ]]; then
    jq --arg k "$key" --argjson v "$value" '.[$k] = $v' "$STATE_FILE" > "$STATE_FILE.tmp" && mv "$STATE_FILE.tmp" "$STATE_FILE"
  # Handle null
  elif [[ "$value" == "null" ]]; then
    jq --arg k "$key" '.[$k] = null' "$STATE_FILE" > "$STATE_FILE.tmp" && mv "$STATE_FILE.tmp" "$STATE_FILE"
  else
    jq --arg k "$key" --arg v "$value" '.[$k] = $v' "$STATE_FILE" > "$STATE_FILE.tmp" && mv "$STATE_FILE.tmp" "$STATE_FILE"
  fi

  echo "Updated: $key = $value"
}

cmd_get() {
  init_state
  local key="${1:?Key required}"
  jq -r --arg k "$key" '.[$k] // "Not set"' "$STATE_FILE"
}

cmd_reset() {
  rm -f "$STATE_FILE"
  init_state
  echo "Progress reset."
}

usage() {
  echo "Usage: open-batch-track <command> [args]"
  echo ""
  echo "Commands:"
  echo "  status              Show current preparation progress"
  echo "  set <key> <value>   Update a progress field"
  echo "  get <key>           Get a progress field value"
  echo "  reset               Reset all progress"
  echo ""
  echo "Keys:"
  echo "  founder_name            Founder's name"
  echo "  company_name            Company name"
  echo "  attendance_mode         in-person | virtual"
  echo "  presenting              true | false"
  echo "  two_sentence_pitch      The locked-in pitch text"
  echo "  pitch_locked            true | false"
  echo "  pitch_feedback_reminded true | false"
  echo "  vertebrae               The confirmed vertebrae text"
  echo "  vertebrae_confirmed     true | false"
  echo "  pitch_script            The confirmed full pitch script"
  echo "  pitch_script_confirmed  true | false"
  echo "  slide_done              true | false"
  echo "  practice_session        Date registered for (e.g. 'March 4')"
  echo "  demo_day_rsvp           true | false"
  echo "  session_rating          1-5 usefulness rating"
  echo "  nps_score               0-10 NPS score for the batch"
}

case "${1:-}" in
  status)
    cmd_status
    ;;
  set)
    cmd_set "${2:-}" "${3:-}"
    ;;
  get)
    cmd_get "${2:-}"
    ;;
  reset)
    cmd_reset
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage
    exit 1
    ;;
esac

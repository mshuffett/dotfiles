#!/bin/bash
set -euo pipefail

REAL_HOME="${HOME}"
DOTFILES_DIR="${DOTFILES_DIR:-$REAL_HOME/.dotfiles}"
STATE_FILE="$REAL_HOME/.config/skill-profile/state.json"
OVERLAY_BASE_DIR="$REAL_HOME/.local/share/skill-profile/codex-homes"
REPO_OVERRIDE_BASE_DIR="$DOTFILES_DIR/codex/profile-overrides"
LOCAL_OVERRIDE_BASE_DIR="$REAL_HOME/.config/skill-profile/codex-overrides"
REAL_CODEX_DIR="$REAL_HOME/.codex"
REAL_AGENTS_DIR="$REAL_HOME/.agents"

current_profile() {
  if [[ ! -f "$STATE_FILE" ]] || ! command -v jq >/dev/null 2>&1; then
    return 0
  fi
  jq -r '.runtimes.codex.currentProfile // empty' "$STATE_FILE" 2>/dev/null || true
}

profile_slug() {
  local profile="$1"
  printf '%s' "$profile" | tr -cs 'a-zA-Z0-9._-' '-'
}

link_children_except_skills() {
  local src_dir="$1"
  local dst_dir="$2"

  [[ -d "$src_dir" ]] || return 0
  mkdir -p "$dst_dir"

  while IFS= read -r child; do
    local name
    local dst_path
    name="$(basename "$child")"
    [[ "$name" == "skills" || "$name" == "plugins" || "$name" == ".agentops-codex-install.json" ]] && continue
    dst_path="$dst_dir/$name"
    if [[ -e "$dst_path" && ! -L "$dst_path" ]]; then
      continue
    fi
    ensure_symlink "$child" "$dst_path"
  done < <(find "$src_dir" -mindepth 1 -maxdepth 1 -print | sort)
}

link_override_children() {
  local src_dir="$1"
  local dst_dir="$2"

  [[ -d "$src_dir" ]] || return 0
  mkdir -p "$dst_dir"

  while IFS= read -r child; do
    local name
    local dst_path
    name="$(basename "$child")"
    dst_path="$dst_dir/$name"
    ensure_symlink "$child" "$dst_path"
  done < <(find "$src_dir" -mindepth 1 -maxdepth 1 -print | sort)
}

ensure_symlink() {
  local target="$1"
  local link_path="$2"

  mkdir -p "$(dirname "$link_path")"

  if [[ -L "$link_path" ]]; then
    if [[ "$(readlink "$link_path")" == "$target" ]]; then
      return 0
    fi
    rm -f "$link_path"
  elif [[ -e "$link_path" ]]; then
    echo "ERROR: $link_path exists and is not a symlink" >&2
    exit 1
  fi

  ln -s "$target" "$link_path"
}

sync_profile_skills() {
  local profile="$1"
  local skills_dir="$2"

  mkdir -p "$skills_dir"

  while IFS= read -r existing; do
    local target
    target="$(readlink "$existing")"
    [[ "$target" == "$DOTFILES_DIR/agents/skills/"* ]] || continue
    rm -f "$existing"
  done < <(find "$skills_dir" -mindepth 1 -maxdepth 1 -type l -print | sort)

  while IFS= read -r skill; do
    [[ -n "$skill" ]] || continue
    ensure_symlink "$DOTFILES_DIR/agents/skills/$skill" "$skills_dir/$skill"
  done < <("$DOTFILES_DIR/bin/skill-profile" resolve "$profile")
}

apply_profile_overrides() {
  local profile="$1"
  local overlay_home="$2"

  link_override_children \
    "$REPO_OVERRIDE_BASE_DIR/$profile/.codex" \
    "$overlay_home/.codex"
  link_override_children \
    "$REPO_OVERRIDE_BASE_DIR/$profile/.agents" \
    "$overlay_home/.agents"

  link_override_children \
    "$LOCAL_OVERRIDE_BASE_DIR/$profile/.codex" \
    "$overlay_home/.codex"
  link_override_children \
    "$LOCAL_OVERRIDE_BASE_DIR/$profile/.agents" \
    "$overlay_home/.agents"
}

build_overlay() {
  local profile="$1"
  local overlay_home="$2"
  mkdir -p "$overlay_home/.codex/skills" "$overlay_home/.agents/skills"

  link_children_except_skills "$REAL_CODEX_DIR" "$overlay_home/.codex"
  link_children_except_skills "$REAL_AGENTS_DIR" "$overlay_home/.agents"
  sync_profile_skills "$profile" "$overlay_home/.codex/skills"
  apply_profile_overrides "$profile" "$overlay_home"
}

profile_override=""
passthrough_args=()

while (($#)); do
  case "$1" in
    --skill-profile)
      shift
      [[ $# -gt 0 ]] || {
        echo "ERROR: --skill-profile requires a profile name" >&2
        exit 1
      }
      profile_override="$1"
      ;;
    *)
      passthrough_args+=("$1")
      ;;
  esac
  shift || true
done

profile="${profile_override:-$(current_profile)}"

if [[ -z "$profile" ]]; then
  exec codex "${passthrough_args[@]}"
fi

overlay_home="$OVERLAY_BASE_DIR/$(profile_slug "$profile")"
build_overlay "$profile" "$overlay_home"
HOME="$overlay_home" exec codex "${passthrough_args[@]}"
